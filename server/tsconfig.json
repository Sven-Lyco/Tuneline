{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "outDir": "dist",
    "strict": true,
    "skipLibCheck": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "esModuleInterop": true,
    "rootDir": "..",
    "paths": {
      "@tuneline/shared": ["../shared/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts"]
}
