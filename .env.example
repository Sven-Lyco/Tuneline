# ─── Client (client/.env.local) ───────────────────────────────────────────────
# Spotify Developer App Client ID
VITE_SPOTIFY_CLIENT_ID=your_spotify_client_id_here

# Socket.io server URL (defaults to http://[::1]:3001 in dev)
VITE_SERVER_URL=http://[::1]:3001

# ─── Server (set via environment / Coolify) ───────────────────────────────────
# Port the server listens on
PORT=3001

# Allowed origin for CORS (must match your deployed frontend URL)
FRONTEND_ORIGIN=https://your-app.example.com

# Node environment
NODE_ENV=production
