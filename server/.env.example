# ─── Server (set via environment / Coolify) ───────────────────────────────────
# Port the server listens on
PORT=3001

# Allowed origin for CORS (must match your deployed frontend URL)
FRONTEND_ORIGIN=https://your-app.example.com

# Node environment
NODE_ENV=production

# Spotify app credentials (server-side — never exposed to the browser)
SPOTIFY_CLIENT_ID=your_spotify_client_id_here

# Redirect URI registered in your Spotify Developer App
# Dev:  http://[::1]:5174/api/auth/callback
# Prod: https://your-app.example.com/api/auth/callback
SPOTIFY_REDIRECT_URI=https://your-app.example.com/api/auth/callback

